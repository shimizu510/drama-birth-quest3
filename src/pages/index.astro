---
const questModules = import.meta.glob('../data/quests/*.json', { eager: true });

const quests = Object.entries(questModules).map(([filePath, module]) => {
  const data = (module as { default?: Record<string, unknown> }).default ?? module;
  const match = filePath.match(/\/([^/]+)\.json$/);
  const questId =
    (typeof data.id === 'string' && data.id) ||
    (match ? match[1] : 'unknown');

  return {
    id: questId,
    title:
      (typeof data.title === 'string' && data.title) ||
      (typeof data?.titles?.ja === 'string' && data.titles.ja) ||
      (typeof data?.titles?.en === 'string' && data.titles.en) ||
      questId,
  };
});
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Quest Index</title>
  </head>
  <body>
    <main>
      <h1>Quest Index</h1>
      <ul>
        {quests.map((q) => (
          <li>
            <a href={`/quests/${q.id}/`}>{q.title}</a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
