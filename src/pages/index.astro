---
import {
  buildAbsoluteUrl,
  formatDateLabel,
  getQuestDescription,
  getQuestSubtitle,
  normalizeQuest,
} from '../lib/quests';
import { getPlaceDescription, normalizePlace } from '../lib/places';

const site = Astro.site;
const canonical = buildAbsoluteUrl('/', site);
const appDownloadURL = '#download-app';
const questModules = import.meta.glob('../data/quests/*.json', { eager: true });
const placeModules = import.meta.glob('../data/places/*.json', { eager: true });

const quests = Object.entries(questModules)
  .map(([filePath, module]) => normalizeQuest(filePath, module))
  .sort((left, right) => {
    const leftTime = left.updatedAt ? new Date(left.updatedAt).getTime() : 0;
    const rightTime = right.updatedAt ? new Date(right.updatedAt).getTime() : 0;
    return rightTime - leftTime;
  });

const places = Object.entries(placeModules)
  .map(([filePath, module]) => normalizePlace(filePath, module))
  .sort((left, right) => {
    const leftTime = left.updatedAt ? new Date(left.updatedAt).getTime() : 0;
    const rightTime = right.updatedAt ? new Date(right.updatedAt).getTime() : 0;
    return rightTime - leftTime;
  });

const pageTitle = 'Drama Birth Quest Archive';
const pageDescription =
  'クエスト一覧と場所ページをまとめた公開アーカイブです。アプリで登録された場所、関連クエスト、今後追加される写真やコメントの入口になります。';
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="google-site-verification" content="43r4xc_D4boZaBpwXqiFqyuuf29Q-2BJGERdXTmvXVk" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f3eb;
        --surface: rgba(255, 255, 255, 0.84);
        --surface-strong: #fffdf8;
        --text: #1f2937;
        --muted: #5b6472;
        --line: rgba(31, 41, 55, 0.12);
        --accent: #c75a2c;
        --accent-strong: #8c3412;
        --shadow: 0 20px 50px rgba(55, 37, 15, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Hiragino Sans", "Noto Sans JP", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(199, 90, 44, 0.18), transparent 34%),
          linear-gradient(180deg, #f1ebde 0%, var(--bg) 42%, #f8f7f3 100%);
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1100px, calc(100% - 32px));
        margin: 0 auto;
        padding: 24px 0 64px;
      }

      .hero {
        padding: 28px;
        border: 1px solid var(--line);
        border-radius: 28px;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(251, 245, 232, 0.86)),
          var(--surface);
        box-shadow: var(--shadow);
      }

      .eyebrow {
        margin: 0 0 10px;
        color: var(--accent-strong);
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.2rem, 5vw, 4rem);
        line-height: 1.05;
      }

      .lead {
        max-width: 760px;
        margin: 18px 0 0;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.8;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
      }

      .button-primary {
        background: linear-gradient(135deg, var(--accent), var(--accent-strong));
        color: white;
      }

      .button-secondary {
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.7);
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 14px;
        margin-top: 28px;
      }

      .stat {
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.64);
      }

      .stat-label {
        color: var(--muted);
        font-size: 0.88rem;
      }

      .stat-value {
        display: block;
        margin-top: 8px;
        font-size: 1.5rem;
        font-weight: 800;
      }

      .section {
        margin-top: 28px;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: end;
        margin-bottom: 16px;
      }

      .section-header h2 {
        margin: 0;
        font-size: 1.5rem;
      }

      .section-header p {
        margin: 0;
        color: var(--muted);
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
      }

      .content-card {
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 22px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--surface-strong);
        box-shadow: 0 12px 34px rgba(50, 36, 15, 0.08);
        text-decoration: none;
      }

      .content-card h3 {
        margin: 0;
        font-size: 1.2rem;
      }

      .quest-meta,
      .quest-date {
        margin: 0;
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.6;
      }

      .quest-summary {
        margin: 0;
        line-height: 1.8;
      }

      .content-link {
        margin-top: auto;
        color: var(--accent-strong);
        font-weight: 700;
      }

      .download {
        margin-top: 28px;
        padding: 24px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: linear-gradient(135deg, rgba(199, 90, 44, 0.1), rgba(255, 255, 255, 0.9));
      }

      .download h2,
      .download p {
        margin: 0;
      }

      .download p {
        margin-top: 10px;
        color: var(--muted);
        line-height: 1.8;
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100% - 20px, 1100px);
          padding-top: 14px;
        }

        .hero,
        .content-card,
        .download {
          border-radius: 20px;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="hero">
        <p class="eyebrow">Quest Discovery</p>
        <h1>クエストと場所の公開アーカイブ</h1>
        <p class="lead">
          アプリ内で公開されたクエストと、MapKit から登録された場所ページをまとめています。
          これから写真、コメント、評価が場所ごとに集約されていく入口です。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#places">場所ページを見る</a>
          <a class="button button-secondary" href="#quest-list">公開クエスト一覧へ</a>
        </div>
        <div class="stats">
          <div class="stat">
            <span class="stat-label">公開クエスト</span>
            <strong class="stat-value">{quests.length}</strong>
          </div>
          <div class="stat">
            <span class="stat-label">登録済みの場所</span>
            <strong class="stat-value">{places.length}</strong>
          </div>
        </div>
      </section>

      <section class="section" id="places">
        <div class="section-header">
          <div>
            <h2>場所ページ</h2>
            <p>MapKit から登録された場所を、アプリ独自データベースとして公開する一覧です。</p>
          </div>
          <a class="button button-secondary" href="/places/">場所一覧へ</a>
        </div>
        <div class="card-grid">
          {places.slice(0, 6).map((place) => (
            <a class="content-card" href={place.webPagePath}>
              <div>
                <h3>{place.title}</h3>
                <p class="quest-meta">{place.address}</p>
                <p class="quest-meta">
                  クエスト {place.questCount}件 / 写真 {place.photoCount}件 / コメント {place.commentCount}件
                </p>
              </div>
              <p class="quest-summary">{getPlaceDescription(place)}</p>
              <span class="content-link">場所ページを見る</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section" id="quest-list">
        <div class="section-header">
          <div>
            <h2>公開クエスト一覧</h2>
            <p>各クエストページは個別URLで公開され、場所ページと並行して運用されます。</p>
          </div>
        </div>
        <div class="card-grid">
          {quests.map((quest) => (
            <a class="content-card" href={quest.webPagePath}>
              <div>
                <h3>{quest.title}</h3>
                {getQuestSubtitle(quest) ? <p class="quest-meta">{getQuestSubtitle(quest)}</p> : null}
              </div>
              <p class="quest-summary">{getQuestDescription(quest)}</p>
              {formatDateLabel(quest.updatedAt) ? (
                <p class="quest-date">最終更新: {formatDateLabel(quest.updatedAt)}</p>
              ) : null}
              <span class="content-link">詳細ページを見る</span>
            </a>
          ))}
        </div>
      </section>

      <section class="download" id="download-app">
        <h2>場所ページの拡張予定</h2>
        <p>
          場所ページには今後、ユーザー写真、コメント、評価、関連クエストが段階的に追加されます。
          現時点では場所登録と公開URLの基盤まで反映しています。
        </p>
      </section>
    </main>
  </body>
</html>
