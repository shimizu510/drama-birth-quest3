---
import { formatDateLabel } from '../../lib/quests';
import { formatPlaceRating, getPlaceDescription, normalizePlace } from '../../lib/places';

const placeModules = import.meta.glob('../../data/places/*.json', { eager: true });
const places = Object.entries(placeModules)
  .map(([filePath, module]) => normalizePlace(filePath, module))
  .sort((left, right) => left.title.localeCompare(right.title, 'ja'));
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>場所一覧 | Drama Birth Quest Archive</title>
    <meta name="description" content="Drama Birth Quest Archive に登録された場所ページの一覧です。" />
    <style>
      body { margin: 0; font-family: "Hiragino Sans", "Noto Sans JP", sans-serif; background: #f6f2ea; color: #1f2937; }
      .shell { width: min(1100px, calc(100% - 32px)); margin: 0 auto; padding: 24px 0 64px; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid rgba(31,41,55,0.12); border-radius: 24px; padding: 20px; box-shadow: 0 16px 42px rgba(43,34,19,0.08); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px,1fr)); gap: 16px; }
      a { color: inherit; text-decoration: none; }
      .meta { color: #617080; line-height: 1.7; }
      .link { color: #8a3918; font-weight: 700; }
    </style>
  </head>
  <body>
    <main class="shell">
      <h1>場所一覧</h1>
      <p class="meta">アプリから登録された場所ページの一覧です。今後、写真・コメント・評価がここに集約されます。</p>
      <div class="grid">
        {places.map((place) => (
          <a class="card" href={place.webPagePath}>
            <h2>{place.title}</h2>
            <p class="meta">{place.address}</p>
            <p class="meta">評価: {formatPlaceRating(place.ratingAverage)} / 更新: {formatDateLabel(place.updatedAt ?? place.createdAt)}</p>
            <p class="meta">クエスト {place.questCount}件 / 写真 {place.photoCount}件 / コメント {place.commentCount}件</p>
            <p>{getPlaceDescription(place)}</p>
            <span class="link">詳細を見る</span>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>
