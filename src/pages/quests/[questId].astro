---
export async function getStaticPaths() {
  const questModules = import.meta.glob('../../data/quests/*.json', { eager: true });

  return Object.entries(questModules).map(([filePath, module]) => {
    const data = (module as { default?: Record<string, unknown> }).default ?? module;
    const match = filePath.match(/\/([^/]+)\.json$/);
    const questId =
      (typeof data.id === 'string' && data.id) ||
      (match ? match[1] : 'unknown');

    return {
      params: { questId },
      props: { quest: { ...data, id: questId } },
    };
  });
}

const { quest } = Astro.props;
const title = quest.title || quest?.titles?.ja || quest?.titles?.en || quest.id;
const synopsis = quest.synopsis || quest?.synopses?.ja || quest?.synopses?.en;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      {synopsis ? <p>{synopsis}</p> : null}
      <dl>
        <dt>Quest ID</dt>
        <dd>{quest.id}</dd>
      </dl>
      <pre style="overflow:auto; background:#f6f8fa; padding:12px; border-radius:6px;">
        {JSON.stringify(quest, null, 2)}
      </pre>
      <p>
        <a href="/">Home</a>
      </p>
    </main>
  </body>
</html>